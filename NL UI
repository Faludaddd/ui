NeverLose.UnloadEnabled = true;


-- =======================================================================
-- MODIFICATION 2 — Add NeverLose:Unload() function
-- -----------------------------------------------------------------------
-- INSERT this function right AFTER the existing NeverLose:AddQuery()
-- function definition.
-- =======================================================================

function NeverLose:Unload()
	-- Disconnect all tracked signals
	for _, signal in next, NeverLose.GlobalSignals do
		pcall(function()
			signal:Disconnect();
		end);
	end;
	table.clear(NeverLose.GlobalSignals);

	-- Destroy the main ScreenGui (removes all UI)
	if NeverLose.ScreenGui then
		NeverLose.ScreenGui:Destroy();
	end;

	-- Clear registries and flags
	table.clear(NeverLose.Flags);
	table.clear(NeverLose.NameRegisitry);
	table.clear(NeverLose.RegisiteryColor);
end;


