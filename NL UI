-- MODIFICATION 3 — Add Minimize and Close Buttons
-- -----------------------------------------------------------------------
-- Inside function NeverLose:CreateWindow(Config), FIND the drag-handle
-- block that looks like this:
--
--   do
--       local Frame = Instance.new("Frame")
--       Frame.Parent = WindowFrame
