-- MODIFICATION 5 — Add UserSettings Popup (3D Menu + Unload)
-- -----------------------------------------------------------------------
-- Inside NeverLose:CreateWindow, FIND the BottomFrame mouse-leave handler:
--
--   NeverLose:AddSignal(BottomFrame.MouseLeave:Connect(LPH_NO_VIRTUALIZE(function()
--       NeverLose.PlayAnimate(UserSettingButton,SlowyTween , {
--           TextTransparency = 0.5
--       })
--   end)))
--
-- INSERT the following block directly AFTER that handler:
-- =======================================================================

-- ── User Settings Popup ─────────────────────────────────────────────
do
	local UserSettingsPopup = Instance.new("Frame")
	local USPCorner = Instance.new("UICorner")
	local USPStroke = Instance.new("UIStroke")
	local USPList = Instance.new("UIListLayout")
	local USPShadow = NeverLose:CreateShadow(UserSettingsPopup);

	UserSettingsPopup.Name = NeverLose.RandomString();
	UserSettingsPopup.Parent = NeverLose.ScreenGui;
	UserSettingsPopup.BackgroundColor3 = Color3.fromRGB(20, 22, 27);
	UserSettingsPopup.BackgroundTransparency = 1;
	UserSettingsPopup.BorderSizePixel = 0;
	UserSettingsPopup.ClipsDescendants = true;
	UserSettingsPopup.Position = UDim2.new(0, 0, 0, 0);
	UserSettingsPopup.Size = UDim2.new(0, 175, 0, 0);
	UserSettingsPopup.ZIndex = 50;
	UserSettingsPopup.Visible = false;

	USPCorner.CornerRadius = UDim.new(0, 10);
	USPCorner.Parent = UserSettingsPopup;

	USPStroke.Transparency = 0.650;
	USPStroke.Color = Color3.fromRGB(45, 48, 58);
	USPStroke.Parent = UserSettingsPopup;

	USPList.Parent = UserSettingsPopup;
	USPList.HorizontalAlignment = Enum.HorizontalAlignment.Center;
	USPList.SortOrder = Enum.SortOrder.LayoutOrder;
	USPList.Padding = UDim.new(0, 2);

	NeverLose:AddSignal(USPList:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(LPH_NO_VIRTUALIZE(function()
		NeverLose.PlayAnimate(UserSettingsPopup, SlowyTween, {
			Size = UDim2.new(0, 175, 0, USPList.AbsoluteContentSize.Y + 10)
		});
	end)));

	NeverLose:AddSignal(UserSettingsPopup:GetPropertyChangedSignal('BackgroundTransparency'):Connect(LPH_NO_VIRTUALIZE(function()
		if UserSettingsPopup.BackgroundTransparency > 0.9 then
			UserSettingsPopup.Visible = false;
			UserSettingsPopup.Parent = nil;
		else
			UserSettingsPopup.Visible = true;
			if NeverLose.Global3DRenderMode then
				UserSettingsPopup.Parent = NeverLose.GlobalSurfaceGui;
			else
				UserSettingsPopup.Parent = NeverLose.ScreenGui;
			end;
		end;
	end)));

	-- Helper: create a popup row
	local function MakeSettingsRow(parent, iconText, iconColor, labelText, labelColor, zidx, callback)
		local RowFrame = Instance.new("Frame")
		local RowCorner = Instance.new("UICorner")
		local RowIcon = Instance.new("TextLabel")
		local RowLabel = Instance.new("TextLabel")

		RowFrame.Name = NeverLose.RandomString();
		RowFrame.Parent = parent;
		RowFrame.BackgroundColor3 = Color3.fromRGB(29, 31, 38);
		RowFrame.BackgroundTransparency = 1;
		RowFrame.BorderSizePixel = 0;
		RowFrame.Size = UDim2.new(1, -10, 0, 32);
		RowFrame.ZIndex = zidx;

		RowCorner.CornerRadius = UDim.new(0, 6);
		RowCorner.Parent = RowFrame;

		RowIcon.Name = NeverLose.RandomString();
		RowIcon.Parent = RowFrame;
		RowIcon.AnchorPoint = Vector2.new(0, 0.5);
		RowIcon.BackgroundTransparency = 1;
		RowIcon.Position = UDim2.new(0, 8, 0.5, 0);
		RowIcon.Size = UDim2.new(0, 20, 0, 20);
		RowIcon.ZIndex = zidx + 1;
		RowIcon.FontFace = NeverLose.BuiltInBold;
		RowIcon.Text = iconText;
		RowIcon.TextColor3 = iconColor;
		RowIcon.TextSize = 16;
		RowIcon.TextWrapped = true;

		RowLabel.Name = NeverLose.RandomString();
		RowLabel.Parent = RowFrame;
		RowLabel.AnchorPoint = Vector2.new(0, 0.5);
		RowLabel.BackgroundTransparency = 1;
		RowLabel.Position = UDim2.new(0, 32, 0.5, 0);
		RowLabel.Size = UDim2.new(1, -40, 0, 20);
		RowLabel.ZIndex = zidx + 1;
		RowLabel.Font = Enum.Font.GothamMedium;
		RowLabel.Text = labelText;
		RowLabel.TextColor3 = labelColor;
		RowLabel.TextSize = 13;
		RowLabel.TextXAlignment = Enum.TextXAlignment.Left;

		local rowInput = NeverLose:CreateInput(RowFrame, LPH_NO_VIRTUALIZE(callback));

		NeverLose:AddSignal(rowInput.MouseEnter:Connect(LPH_NO_VIRTUALIZE(function()
			NeverLose.PlayAnimate(RowFrame, SlowyTween, { BackgroundTransparency = 0.3 });
		end)));

		NeverLose:AddSignal(rowInput.MouseLeave:Connect(LPH_NO_VIRTUALIZE(function()
			NeverLose.PlayAnimate(RowFrame, SlowyTween, { BackgroundTransparency = 1 });
		end)));

		return RowFrame;
	end;

	-- 3D Menu row (only if renderer is enabled)
	if Window.Enable3DRenderer then
		MakeSettingsRow(
			UserSettingsPopup,
			"3d-cube-arrow-left",
			Color3.fromRGB(200, 200, 200),
			"3D Menu",
			Color3.fromRGB(220, 220, 220),
			52,
			function()
				if Window.Set3DRender then
					Window.__3DRender = not Window.__3DRender;
					Window:Set3DRender(Window.__3DRender);
				end;
			end
		);
	end;

	-- Unload row
	MakeSettingsRow(
		UserSettingsPopup,
		"circle-x",
		Color3.fromRGB(255, 80, 80),
		"Unload",
		Color3.fromRGB(255, 100, 100),
		52,
		function()
			NeverLose:Unload();
		end
	);

	-- Toggle popup on UserSettingButton click
	local SettingsPopupOpen = false;
	local settingsClickSignal = nil;

	NeverLose:CreateInput(UserSettingButton, LPH_NO_VIRTUALIZE(function()
		SettingsPopupOpen = not SettingsPopupOpen;

		if settingsClickSignal then
			settingsClickSignal:Disconnect();
			settingsClickSignal = nil;
		end;

		if SettingsPopupOpen then
			-- Position above the bottom frame
			UserSettingsPopup.Position = UDim2.fromOffset(
				BottomFrame.AbsolutePosition.X + 5,
				BottomFrame.AbsolutePosition.Y - UserSettingsPopup.AbsoluteSize.Y - 5
			);

			NeverLose.PlayAnimate(UserSettingsPopup, SlowyTween, {
				BackgroundTransparency = 0.035
			});
			NeverLose.PlayAnimate(USPStroke, SlowyTween, {
				Transparency = 0.650
			});
			USPShadow:Render(true);

			-- Auto-close on outside click
			settingsClickSignal = UserInputService.InputBegan:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
					if not NeverLose:IsMouseOverFrame(UserSettingsPopup) and not NeverLose:IsMouseOverFrame(BottomFrame) then
						SettingsPopupOpen = false;
						if settingsClickSignal then
							settingsClickSignal:Disconnect();
							settingsClickSignal = nil;
						end;
						NeverLose.PlayAnimate(UserSettingsPopup, SlowyTween, {
							BackgroundTransparency = 1
						});
						NeverLose.PlayAnimate(USPStroke, SlowyTween, {
							Transparency = 1
						});
						USPShadow:Render(false);
					end;
				end;
			end);
		else
			NeverLose.PlayAnimate(UserSettingsPopup, SlowyTween, {
				BackgroundTransparency = 1
			});
			NeverLose.PlayAnimate(USPStroke, SlowyTween, {
				Transparency = 1
			});
			USPShadow:Render(false);
		end;
	end));
end


