-- ── Minimize & Close Buttons (top-right of window) ──────────────────
do
	Window.Minimized = false;
	local OriginalWindowSize = Window.Size;

	-- Minimize Button
	local MinimizeBtn = Instance.new("Frame")
	local MinimizeBtnCorner = Instance.new("UICorner")
	local MinimizeBtnLabel = Instance.new("TextLabel")

	MinimizeBtn.Name = NeverLose.RandomString();
	MinimizeBtn.Parent = WindowFrame;
	MinimizeBtn.AnchorPoint = Vector2.new(1, 0);
	MinimizeBtn.BackgroundColor3 = Color3.fromRGB(30, 32, 40);
	MinimizeBtn.BackgroundTransparency = 0;
	MinimizeBtn.BorderSizePixel = 0;
	MinimizeBtn.Position = UDim2.new(1, -40, 0, 10);
	MinimizeBtn.Size = UDim2.new(0, 26, 0, 26);
	MinimizeBtn.ZIndex = 20;

	MinimizeBtnCorner.CornerRadius = UDim.new(0, 6);
	MinimizeBtnCorner.Parent = MinimizeBtn;

	MinimizeBtnLabel.Name = NeverLose.RandomString();
	MinimizeBtnLabel.Parent = MinimizeBtn;
	MinimizeBtnLabel.AnchorPoint = Vector2.new(0.5, 0.5);
	MinimizeBtnLabel.BackgroundTransparency = 1;
	MinimizeBtnLabel.Position = UDim2.new(0.5, 0, 0.5, -1);
	MinimizeBtnLabel.Size = UDim2.new(1, 0, 1, 0);
	MinimizeBtnLabel.ZIndex = 21;
	MinimizeBtnLabel.Font = Enum.Font.GothamBold;
	MinimizeBtnLabel.Text = "—";
	MinimizeBtnLabel.TextColor3 = Color3.fromRGB(190, 190, 190);
	MinimizeBtnLabel.TextSize = 16;

	-- Close Button
	local CloseBtn = Instance.new("Frame")
	local CloseBtnCorner = Instance.new("UICorner")
	local CloseBtnLabel = Instance.new("TextLabel")

	CloseBtn.Name = NeverLose.RandomString();
	CloseBtn.Parent = WindowFrame;
	CloseBtn.AnchorPoint = Vector2.new(1, 0);
	CloseBtn.BackgroundColor3 = Color3.fromRGB(30, 32, 40);
	CloseBtn.BackgroundTransparency = 0;
	CloseBtn.BorderSizePixel = 0;
	CloseBtn.Position = UDim2.new(1, -10, 0, 10);
	CloseBtn.Size = UDim2.new(0, 26, 0, 26);
	CloseBtn.ZIndex = 20;

	CloseBtnCorner.CornerRadius = UDim.new(0, 6);
	CloseBtnCorner.Parent = CloseBtn;

	CloseBtnLabel.Name = NeverLose.RandomString();
	CloseBtnLabel.Parent = CloseBtn;
	CloseBtnLabel.AnchorPoint = Vector2.new(0.5, 0.5);
	CloseBtnLabel.BackgroundTransparency = 1;
	CloseBtnLabel.Position = UDim2.new(0.5, 0, 0.5, 0);
	CloseBtnLabel.Size = UDim2.new(1, 0, 1, 0);
	CloseBtnLabel.ZIndex = 21;
	CloseBtnLabel.Font = Enum.Font.GothamBold;
	CloseBtnLabel.Text = "✕";
	CloseBtnLabel.TextColor3 = Color3.fromRGB(190, 190, 190);
	CloseBtnLabel.TextSize = 13;

	-- Minimize click handler
	local MinInput = NeverLose:CreateInput(MinimizeBtn, LPH_NO_VIRTUALIZE(function()
		Window.Minimized = not Window.Minimized;

		if Window.Minimized then
			NeverLose.PlayAnimate(WindowFrame, VSlowTween, {
				Size = UDim2.new(OriginalWindowSize.X.Scale, OriginalWindowSize.X.Offset, 0, 50)
			});
			MinimizeBtnLabel.Text = "+";
		else
			NeverLose.PlayAnimate(WindowFrame, VSlowTween, {
				Size = OriginalWindowSize
			});
			MinimizeBtnLabel.Text = "—";
		end;
	end));

	-- Close click handler
	local CloseInput = NeverLose:CreateInput(CloseBtn, LPH_NO_VIRTUALIZE(function()
		NeverLose:Unload();
	end));

	-- Hover effects — Minimize
	NeverLose:AddSignal(MinInput.MouseEnter:Connect(LPH_NO_VIRTUALIZE(function()
		NeverLose.PlayAnimate(MinimizeBtn, SlowyTween, {
			BackgroundColor3 = Color3.fromRGB(50, 52, 62)
		});
		NeverLose.PlayAnimate(MinimizeBtnLabel, SlowyTween, {
			TextColor3 = Color3.fromRGB(255, 255, 255)
		});
	end)));

	NeverLose:AddSignal(MinInput.MouseLeave:Connect(LPH_NO_VIRTUALIZE(function()
		NeverLose.PlayAnimate(MinimizeBtn, SlowyTween, {
			BackgroundColor3 = Color3.fromRGB(30, 32, 40)
		});
		NeverLose.PlayAnimate(MinimizeBtnLabel, SlowyTween, {
			TextColor3 = Color3.fromRGB(190, 190, 190)
		});
	end)));

	-- Hover effects — Close (red tint)
	NeverLose:AddSignal(CloseInput.MouseEnter:Connect(LPH_NO_VIRTUALIZE(function()
		NeverLose.PlayAnimate(CloseBtn, SlowyTween, {
			BackgroundColor3 = Color3.fromRGB(160, 45, 45)
		});
		NeverLose.PlayAnimate(CloseBtnLabel, SlowyTween, {
			TextColor3 = Color3.fromRGB(255, 255, 255)
		});
	end)));

	NeverLose:AddSignal(CloseInput.MouseLeave:Connect(LPH_NO_VIRTUALIZE(function()
		NeverLose.PlayAnimate(CloseBtn, SlowyTween, {
			BackgroundColor3 = Color3.fromRGB(30, 32, 40)
		});
		NeverLose.PlayAnimate(CloseBtnLabel, SlowyTween, {
			TextColor3 = Color3.fromRGB(190, 190, 190)
		});
	end)));

	-- ── Store references for SetRender (see MODIFICATION 6) ──
	Window._MinimizeBtn = MinimizeBtn;
	Window._MinimizeBtnLabel = MinimizeBtnLabel;
	Window._CloseBtn = CloseBtn;
	Window._CloseBtnLabel = CloseBtnLabel;
end


